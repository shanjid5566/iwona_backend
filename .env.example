# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
DATABASE_URL=""

# JWT Configuration
JWT_SECRET=
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# ============================================
# EMAIL CONFIGURATION
# ============================================

# SMTP Configuration (Active - Using Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# NOTE: For Gmail, you MUST use "App Password" instead of your regular password
# How to get Gmail App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification if not already enabled
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Create a new app password for "Mail"
# 5. Copy the 16-character password and use it as SMTP_PASSWORD

# Mailchimp Configuration (Commented - Keep for future use if needed)
# MAILCHIMP_API_KEY=your-mailchimp-api-key

# ============================================
# MAILCHIMP MARKETING CONFIGURATION
# ============================================
MAILCHIMP_MARKETING_API_KEY=your-mailchimp-marketing-api-key
MAILCHIMP_SERVER_PREFIX=us4
MAILCHIMP_AUDIENCE_ID=your-audience-list-id

# NOTE: Mailchimp Marketing API (for adding subscribers to mailing list)
# - API Key: Get from Mailchimp → Account → Extras → API keys
# - Server Prefix: The part after the dash in your API key (e.g., "us4" from "xxxxx-us4")
# - Audience ID: Get from Mailchimp → Audience → Settings → Audience name and defaults

# ============================================
# STRIPE CONFIGURATION
# ============================================
STRIPE_SECRET_KEY=test_key
STRIPE_PUBLISHABLE_KEY=test_key

# Payment Configuration
DEFAULT_PAYMENT_AMOUNT=9.99
PAYMENT_CURRENCY=eur

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
