// Prisma Schema File
// https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
 
}

datasource db {
    provider = "postgresql"
}

// 1. User Model (Authentication & Profiles)
model User {
    id               String     @id @default(uuid())
    email            String     @unique
    firstName        String
    lastName         String
    fullName         String
    password         String
    role             Role       @default(USER)
    homeAirport      String?
    status           UserStatus @default(PENDING)
    isEmailVerified  Boolean    @default(false)
    createdAt        DateTime   @default(now())
    updatedAt        DateTime   @updatedAt

    // Relationships
    subscriptions      Subscription[] // Changed from singular to plural for multiple subscriptions
    payments           Payment[]
    emailVerifications EmailVerification[]
    giveawayEntries    GiveawayEntry[]
}

// Email Verification Model (also used for password reset OTP)
model EmailVerification {
    id        String   @id @default(uuid())
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    code      String   // 4-digit OTP code
    expiresAt DateTime // Code expires in 10 minutes
    isUsed    Boolean  @default(false)
    createdAt DateTime @default(now())

    @@index([userId])
    @@index([code])
}

enum Role {
    USER
    ADMIN
}

enum UserStatus {
    PENDING  // Not verified or not paid
    ACTIVE   // Email verified and payment completed
    INACTIVE // Account deactivated
}

// 2. Subscription Model (Membership details)
model Subscription {
    id                    String    @id @default(uuid())
    userId                String
    user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    planName              String    @default("Annual Membership")
    amount                Float     @default(9.99)
    startDate             DateTime  @default(now())
    endDate               DateTime  // When the subscription expires
    isActive              Boolean   @default(true)
    isExpired             Boolean   @default(false)  // Automatically set to true when endDate passes
    isRenewed             Boolean   @default(false)  // Set to true if user buys again
    renewedSubscriptionId String?   // Link to new subscription when renewed
    stripeSubId           String?   @unique // Stripe subscription ID
    isGifted              Boolean   @default(false) // Whether this is a gifted subscription
    giftedBy              String?   // User ID of the person who gifted this subscription
    reminderSent          Boolean   @default(false) // Whether 1-month expiry reminder was sent
    reminderSentAt        DateTime? // When the reminder was sent
    createdAt             DateTime  @default(now())
    updatedAt             DateTime  @updatedAt

    @@index([userId])
    @@index([isActive, endDate])
}

// 3. Payment Log (Transaction History)
model Payment {
    id            String        @id @default(uuid())
    userId        String
    user          User          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    transactionId String        @unique // Stripe payment intent ID
    amount        Float
    status        PaymentStatus
    paymentMethod String? // card, paypal, etc.
    createdAt     DateTime      @default(now())
}

enum PaymentStatus {
    SUCCESS
    FAILED
    PENDING
}

// 4. Travel Guide Model
model TravelGuide {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  category    String   // Cultural, Adventure, Food, Nature, etc.
  heroImage   String?
  readTime    String
  location    String
  content     Json
  author      String   @default("Admin")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

// 5. Travel Deal Model
model TravelDeal {
    id                 String     @id @default(uuid())
    title              String
    description        String     @db.Text
    price              Float
    discount           Float?     // Discount percentage (0-100)
    destination        String
    airport            String
    dealImage          String?    // Deal image URL
    travelStartDate    DateTime?
    travelEndDate      DateTime?
    flightBookingLink  String?
    hotelBookingLink   String?
    status             DealStatus @default(ACTIVE)
    isFeatured         Boolean    @default(false)
    createdAt          DateTime   @default(now())
    updatedAt          DateTime   @updatedAt

    @@index([status])
    @@index([isFeatured])
}

enum DealStatus {
    ACTIVE
    EXPIRED
}

// 6. Giveaway Model
model Giveaway {
    id              String          @id @default(uuid())
    title           String
    description     String          @db.Text
    giveawayImage   String?         // Giveaway image URL
    status          GiveawayStatus  @default(DRAFT)
    isMonthlyActive Boolean         @default(false)
    startDate       DateTime
    endDate         DateTime
    createdAt       DateTime        @default(now())
    updatedAt       DateTime        @updatedAt

    // Relationships
    entries         GiveawayEntry[]

    @@index([status])
    @@index([isMonthlyActive])
}

enum GiveawayStatus {
    DRAFT
    UPCOMING
    ACTIVE
    EXPIRED
}

// 7. Giveaway Entry Model (Tracks user participation)
model GiveawayEntry {
    id          String    @id @default(uuid())
    giveawayId  String
    userId      String
    enteredAt   DateTime  @default(now())

    // Relationships
    giveaway    Giveaway  @relation(fields: [giveawayId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    user        User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    @@unique([giveawayId, userId]) // One entry per user per giveaway
    @@index([giveawayId])
    @@index([userId])
}

// 8. Website Settings (Admin Control)
model Settings {
    id                  Int     @id @default(1)
    websiteName         String  @default("Travel in a Click")
    contactEmail        String
    defaultHomeAirport  String
    aboutUsText         String  @db.Text
    requireEmailConfirm Boolean @default(true)
    allowPublicReg      Boolean @default(true)
}